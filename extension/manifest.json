{
  "manifest_version": 3,
  "name": "Naraseo AI - Page Audit & Rank Tracker",
  "short_name": "Naraseo AI",
  "version": "1.0.0",
  "description": "SEO audit sidebar for any webpage. Scores titles, meta tags, Core Web Vitals & headings. AI chat explains issues and suggests fixes.",
  "author": "SEO AI",
  "homepage_url": "https://seoai.app",

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "sidePanel",
    "tabs",
    "geolocation",
    "notifications",
    "alarms",
    "contextMenus",
    "downloads"
  ],

  "host_permissions": [
    "https://naraseoai.onrender.com/*",
    "http://127.0.0.1:3001/*",
    "<all_urls>"
  ],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_title": "Naraseo AI — Audit This Page",
    "default_icons": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Open Naraseo AI sidebar"
    }
  },

  "side_panel": {
    "default_path": "sidebar.html"
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
